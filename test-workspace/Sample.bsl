// Тестовый модуль для демонстрации возможностей bsl-analyzer

#Область ПрограммныйИнтерфейс

// Экспортная процедура для обработки данных
//
// Параметры:
//  Данные - Строка - входные данные
//  Результат - Строка - результат обработки
//
Процедура ОбработатьДанные(Данные, Результат) Экспорт

    Перем ЛокальнаяПеременная;

    Если ПустаяСтрока(Данные) Тогда
        Результат = "";
        Возврат;
    КонецЕсли;

    ЛокальнаяПеременная = СокрЛП(Данные);
    Результат = ВРег(ЛокальнаяПеременная);

КонецПроцедуры

// Экспортная функция для вычислений
//
// Параметры:
//  Число1 - Число - первое число
//  Число2 - Число - второе число
//
// Возвращаемое значение:
//  Число - сумма чисел
//
Функция ВычислитьСумму(Число1, Число2) Экспорт

    Возврат Число1 + Число2;

КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Служебная процедура
Процедура ВнутренняяОбработка()

    Перем Счетчик;

    Для Счетчик = 1 По 10 Цикл
        Сообщить(Счетчик);
    КонецЦикла;

КонецПроцедуры

// Функция с логическим возвращаемым значением
Функция ПроверитьУсловие(Значение)

    Если Значение > 0 Тогда
        Возврат Истина;
    Иначе
        Возврат Ложь;
    КонецЕсли;

КонецФункции

#КонецОбласти

